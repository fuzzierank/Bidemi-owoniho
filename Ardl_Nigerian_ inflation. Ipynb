   "source": [
    "# Nigeria Inflation ARDL Forecasting with Naira Exchange Rate\n",
    "\n",
    "Interactive notebook for ARDL model and forecasts."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from statsmodels.tsa.api import ARDL\n",
    "\n",
    "df = pd.read_csv('../data/historical_inflation.csv', parse_dates=['date'])\n",
    "df.set_index('date', inplace=True)\n",
    "print(df.tail())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y = df['headline_yoy']\n",
    "X = df[['usd_ngn_avg']]\n",
    "\n",
    "model = ARDL(y, lags=2, exog=X, order=2, trend='c')\n",
    "results = model.fit()\n",
    "print(results.summary())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "forecast_steps = 6\n",
    "future_exog = pd.DataFrame({'usd_ngn_avg': [1370] * forecast_steps}, index=pd.date_range(start=df.index[-1], periods=forecast_steps, freq='ME'))\n",
    "forecast = results.forecast(steps=forecast_steps, exog=future_exog)\n",
    "print(forecast)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.plot(df.index, y, label='Actual')\n",
    "plt.plot(forecast.index, forecast, label='Forecast', linestyle='--')\n",
    "plt.title('ARDL Inflation Forecast')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  }
